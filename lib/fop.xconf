<?xml version="1.0" encoding="UTF-8"?>
<fop version="1.0">
 
   <base>.</base> 
   <source-resolution>120</source-resolution>
   <target-resolution>120</target-resolution>
  
  <!--<default-page-settings height="11in" width="8.26in"/>-->
  
  <renderers>
    <renderer mime="application/pdf">
      <filterList>
        <value>flate</value>
      </filterList>
      
      <fonts>
          <auto-detect/>
      </fonts>
    </renderer>
  </renderers>
</fop>
